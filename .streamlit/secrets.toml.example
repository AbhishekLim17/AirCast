# .streamlit/secrets.toml
# Used by Streamlit Community Cloud — add these values in the Cloud UI under App Settings → Secrets
# DO NOT commit real values here — keep this file in .gitignore

WAQI_API_TOKEN = "your_waqi_token"
SUPABASE_URL   = "https://your-project.supabase.co"
SUPABASE_KEY   = "your_supabase_service_role_key"
HF_TOKEN       = "hf_your_token"
HF_USERNAME    = "your_hf_username"
HF_REPO_NAME   = "ahmedabad-aqi-model"
RETRAIN_MAE_THRESHOLD = "20"
